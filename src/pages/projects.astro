---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/site";
---

<Layout
  title="Projects — Jeremy Ianne"
  description="Projects by Jeremy Ianne — systems, networking, protocols."
>
  <section class="relative border-b border-border">
    <div class="mx-auto max-w-5xl px-6 py-20 sm:px-8 sm:py-28">
      <div
        class="mb-12 flex items-center justify-between font-mono text-[10px] tracking-[0.25em] text-fg-dim uppercase"
      >
        <div class="flex items-center gap-3">
          <span class="text-rust">///</span>
          <span>projects — index</span>
        </div>
        <div>n = {projects.length}</div>
      </div>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-10">
        <div class="lg:col-span-5">
          <p class="mb-4 flex items-center gap-3 font-mono text-xs text-fg-muted">
            <span class="h-px w-8 bg-rust"></span>
            <span>A working archive.</span>
          </p>
          <h1
            class="font-display text-6xl leading-[0.9] tracking-[-0.03em] text-fg sm:text-7xl"
          >
            <span class="block">Projects</span>
            <span class="block italic text-rust">catalog<span class="text-ember">.</span></span>
          </h1>
        </div>

        <div class="lg:col-span-7">
          <p class="max-w-xl text-lg leading-relaxed text-fg-muted">
            Stuff I've built or am building. Click a title to jump to the repo.
            The rest of my noise lives on{" "}
            <a
              href="https://github.com/Jviguy"
              target="_blank"
              rel="noopener noreferrer"
              class="link-oxide text-fg hover:text-rust"
            >
              github.com/Jviguy
            </a>.
          </p>

          <div class="mt-8 flex items-center gap-4">
            <div class="oxide-strip h-[3px] w-32 opacity-80"></div>
            <span
              class="font-mono text-[10px] tracking-[0.3em] text-fg-dim uppercase"
            >
              ↓ the catalog
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative">
    <div class="mx-auto max-w-5xl px-6 sm:px-8">
      <ol class="divide-y divide-border border-b border-border">
        {
          projects.map((p, i) => {
            const num = String(i + 1).padStart(3, "0");
            const Wrapper = p.url ? "a" : "div";
            const wrapperProps = p.url
              ? {
                  href: p.url,
                  target: "_blank",
                  rel: "noopener noreferrer",
                }
              : {};
            const baseClass =
              "grid gap-6 py-10 sm:grid-cols-[auto_1fr_auto] sm:items-baseline sm:gap-10 sm:py-12";
            const hoverClass = p.url
              ? "transition-colors hover:bg-bg-card/40"
              : "";
            return (
              <li class="group relative">
                <Wrapper class={`${baseClass} ${hoverClass}`} {...wrapperProps}>
                  <div class="font-mono text-[11px] text-rust tabular-nums sm:w-12">
                    {num}
                  </div>

                  <div class="min-w-0">
                    <div class="flex items-baseline gap-3">
                      <h3
                        class:list={[
                          "font-display text-3xl tracking-tight sm:text-4xl",
                          p.url
                            ? "text-fg transition-colors group-hover:text-rust"
                            : "text-fg",
                        ]}
                      >
                        {p.title}
                      </h3>
                      {p.url ? (
                        <span
                          class="font-mono text-sm text-fg-dim transition-all group-hover:translate-x-1 group-hover:text-rust"
                          aria-hidden="true"
                        >
                          ↗
                        </span>
                      ) : (
                        <span
                          class="font-mono text-[10px] tracking-[0.25em] text-fg-dimmer uppercase"
                          aria-label="Private"
                        >
                          private
                        </span>
                      )}
                    </div>

                    <p class="mt-4 max-w-2xl leading-relaxed text-fg-muted">
                      {p.description}
                    </p>

                    {p.tech && (
                      <div class="mt-5 flex flex-wrap gap-1.5">
                        {p.tech.map((t) => (
                          <span class="border border-border-strong bg-bg-inset px-2 py-1 font-mono text-[10px] tracking-wide text-fg-dim uppercase">
                            {t}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>

                  <div class="hidden font-mono text-[10px] tracking-[0.25em] text-fg-dimmer uppercase sm:block">
                    {p.tech?.[0] ?? "—"}
                  </div>
                </Wrapper>
              </li>
            );
          })
        }
      </ol>

      <div class="py-16 text-center">
        <p class="font-mono text-xs tracking-wide text-fg-dim">
          more on{" "}
          <a
            href="https://github.com/Jviguy"
            target="_blank"
            rel="noopener noreferrer"
            class="link-oxide text-fg-muted hover:text-rust"
          >
            github.com/Jviguy
          </a>
        </p>
      </div>
    </div>
  </section>
</Layout>
