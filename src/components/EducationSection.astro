---
import Section from "./Section.astro";
import { education } from "../data/site";
---

<Section
  module="03"
  name="registry"
  title="Education, officially on the record."
>
  <div slot="sidebar" class="space-y-6">
    <p class="font-mono text-[11px] text-fg-dim">
      <span class="text-fg-dimmer">cat</span>{" "}
      <span class="text-fg-muted">/etc/education</span>
    </p>
    <p class="text-sm leading-relaxed text-fg-muted">
      Two transfer moves and a dual-enrollment cert, in that order.
    </p>
  </div>

  <ol class="divide-y divide-border border-y border-border">
    {
      education.map((ed, i) => {
        const num = String(i).padStart(2, "0");
        return (
          <li class="grid gap-4 py-7 sm:grid-cols-[auto_1fr_auto] sm:items-baseline sm:gap-8">
            <div class="font-mono text-[11px] text-rust tabular-nums">
              {num}
            </div>

            <div>
              <div class="font-display text-xl tracking-tight text-fg">
                {ed.school}
              </div>
              <div class="mt-1 text-sm text-fg-muted">{ed.degree}</div>
              {ed.note && (
                <div class="mt-2 inline-flex items-center gap-2 border border-border-strong bg-bg-inset px-2 py-1 font-mono text-[10px] text-fg-dim uppercase tracking-wide">
                  <span class="text-rust">*</span>
                  {ed.note}
                </div>
              )}
            </div>

            <div class="text-right font-mono text-[11px] text-fg-dim tabular-nums sm:text-left">
              <div>{ed.period}</div>
              <div class="text-fg-dimmer">{ed.location}</div>
            </div>
          </li>
        );
      })
    }
  </ol>
</Section>
