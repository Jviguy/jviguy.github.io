---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="relative border-t border-border bg-bg-inset/70">
  <div class="oxide-strip h-px w-full opacity-50"></div>

  <div class="mx-auto max-w-6xl px-6 py-12 sm:px-8 sm:py-16">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-7">
        <p
          class="mb-3 font-mono text-[10px] tracking-[0.3em] text-fg-dim uppercase"
        >
          <span class="text-rust">///</span> end of transmission
        </p>
        <p class="font-display text-3xl italic tracking-tight text-fg sm:text-4xl">
          until next packet<span class="text-rust">.</span>
        </p>
      </div>

      <div class="lg:col-span-5">
        <p class="mb-3 font-mono text-[10px] tracking-[0.25em] text-fg-dimmer uppercase">
          find me
        </p>
        <div class="flex flex-col gap-2 font-mono text-sm text-fg-muted">
          <a
            href={site.github}
            target="_blank"
            rel="noopener noreferrer"
            class="link-oxide w-fit transition hover:text-fg"
          >
            github / jviguy
          </a>
          <a
            href={site.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="link-oxide w-fit transition hover:text-fg"
          >
            linkedin / jeremy-ianne
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col-reverse gap-4 border-t border-border pt-6 font-mono text-[10px] tracking-[0.25em] text-fg-dimmer uppercase sm:flex-row sm:items-center sm:justify-between"
    >
      <span>© {year} jeremy ianne</span>
      <span class="flex items-center gap-2">
        <span class="h-1 w-1 rounded-full bg-rust"></span>
        <span>status: ok</span>
      </span>
    </div>
  </div>
</footer>
